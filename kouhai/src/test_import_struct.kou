# Test importing token.kou and accessing Token via factory function

import "token.kou"

fn main():
    # Use factory function instead of direct Token() call
    let t = create_token(20, "fn", 1, 0)
    
    # Access via helper functions
    print(get_token_type(t))
    print(get_token_value(t))
    print(token_type_name(get_token_type(t)))
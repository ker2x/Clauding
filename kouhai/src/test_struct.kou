# Test if struct from same file works

struct MyToken:
    type: I64
    value: Str
    line: I64
    col: I64

fn make_token() -> MyToken:
    let t = MyToken()
    t.type = 1
    t.value = "hello"
    t.line = 1
    t.col = 0
    return t

fn main():
    let t = make_token()
    print(t.type)
    print(t.value)
; Fibonacci: print first 10 numbers
PUSH_INT 0
STORE a          ; a = 0
PUSH_INT 1
STORE b          ; b = 1
PUSH_INT 10
STORE count      ; count = 10

loop:
  LOAD a
  PRINT          ; print a
  LOAD a
  LOAD b
  ADD            ; a + b
  LOAD b
  STORE a        ; a = old b
  STORE b        ; b = a + b
  LOAD count
  PUSH_INT 1
  SUB
  DUP
  STORE count    ; count--
  PUSH_INT 0
  GT             ; count > 0?
  JMP_IF loop

HALT

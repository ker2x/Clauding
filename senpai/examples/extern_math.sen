link "m"

extern fn sqrt(x: Double) -> Double
extern fn floor(x: Double) -> Double
extern fn ceil(x: Double) -> Double
extern fn pow(base: Double, exp: Double) -> Double
extern fn log(x: Double) -> Double

fn main():
    print("sqrt(144) = " + sqrt(144.0).to_str())
    print("floor(3.7) = " + floor(3.7).to_str())
    print("ceil(3.2) = " + ceil(3.2).to_str())
    print("pow(2, 10) = " + pow(2.0, 10.0).to_str())
    print("log(1) = " + log(1.0).to_str())
